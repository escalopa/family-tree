# Frontend (Vercel)
VITE_API_URL=https://API_GATEWAY_DOMAIN

# Yandex Cloud Terraform
YC_CLOUD_ID=aku9nvnuimbpunvfl2ie
YC_FOLDER_ID=akubuo7de4n5uu7cu534
TF_VAR_cloud_id=aku9nvnuimbpunvfl2ie
TF_VAR_folder_id=akubuo7de4n5uu7cu534
TF_VAR_yc_token=$(yc iam create-token)
TF_VAR_zone=ru-central1-a
TF_VAR_name_prefix=family-tree
TF_VAR_container_image_tag=latest
TF_VAR_frontend_origin=https://your-vercel-app.vercel.app
TF_VAR_jwt_secret=replace-with-a-strong-secret

# Preview auth. Keep this enabled until real OAuth credentials are ready.
TF_VAR_oauth_enabled_providers=mock
TF_VAR_enable_mock_auth=true
TF_VAR_seed_test_data=true

# Production OAuth example. Store real provider secrets in Yandex Lockbox and map them
# to the serverless container in infra/yandex/main.tf.
# TF_VAR_oauth_enabled_providers=google,github
# TF_VAR_enable_mock_auth=false
# TF_VAR_seed_test_data=false

# Current backend compatibility note:
# The infrastructure is YDB/YQL-ready, but the Go backend still needs its
# PostgreSQL repository layer migrated to the YDB Go SDK before live YDB use.
