# Frontend (Vercel)
VITE_API_URL=https://API_GATEWAY_DOMAIN

# Yandex Cloud Terraform
YC_CLOUD_ID=b1g00m03hogrja9p1rb0
YC_FOLDER_ID=b1gkimk9k36atshi4uto
TF_VAR_cloud_id=b1g00m03hogrja9p1rb0
TF_VAR_folder_id=b1gkimk9k36atshi4uto
TF_VAR_yc_token=$(yc iam create-token)
TF_VAR_zone=ru-central1-a
TF_VAR_name_prefix=family-tree
TF_VAR_container_image_tag=latest
TF_VAR_frontend_origin=https://family.escalopa.com
TF_VAR_jwt_secret=replace-with-a-strong-secret

# Production auth.
TF_VAR_oauth_enabled_providers=yandex
TF_VAR_enable_mock_auth=false
TF_VAR_seed_test_data=false
TF_VAR_oauth_yandex_client_id=replace-with-yandex-oauth-client-id
TF_VAR_oauth_yandex_client_secret=replace-with-yandex-oauth-client-secret

# Vercel production domain
VERCEL_PROJECT_DOMAIN=family.escalopa.com

# Current backend compatibility note:
# The infrastructure is YDB/YQL-ready, but the Go backend still needs its
# PostgreSQL repository layer migrated to the YDB Go SDK before live YDB use.
