# Frontend (Vercel)
VITE_API_URL=https://family-tree-api.onrender.com

# Backend (Render)
PORT=10000
GIN_MODE=release
LOG_LEVEL=info
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://your-production-domain.com
ENABLE_HSTS=true
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
JWT_SECRET=replace-with-render-generated-secret

# Database (Supabase session pooler or direct Postgres URL)
DATABASE_DSN=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require

# Optional Redis-compatible cache. Leave empty on the free stack; rate limiting is disabled without it.
REDIS_URI=

# Preview auth. Keep this enabled until real OAuth credentials are ready.
OAUTH_REDIRECT_BASE_URL=https://your-vercel-app.vercel.app
OAUTH_ENABLED_PROVIDERS=mock
ENABLE_MOCK_AUTH=true
SEED_TEST_DATA=true

# Production OAuth example. Replace mock config with real providers when credentials are available.
# OAUTH_ENABLED_PROVIDERS=google,github
# ENABLE_MOCK_AUTH=false
# SEED_TEST_DATA=false
# OAUTH_PROVIDER_GOOGLE_CLIENT_ID=
# OAUTH_PROVIDER_GOOGLE_CLIENT_SECRET=
# OAUTH_PROVIDER_GOOGLE_SCOPES=openid,email,profile
# OAUTH_PROVIDER_GITHUB_CLIENT_ID=
# OAUTH_PROVIDER_GITHUB_CLIENT_SECRET=

# Supabase Storage S3-compatible endpoint
S3_ENDPOINT=https://PROJECT_REF.storage.supabase.co/storage/v1/s3
S3_REGION=us-east-1
S3_BUCKET=family-tree
S3_ACCESS_KEY=
S3_SECRET_KEY=
